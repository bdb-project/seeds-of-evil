!----------------------------------------
! trunk
!----------------------------------------
Object trunk "trunk" room30
with
  name 'boot' 'trunk',
  description
  [;
    print "It's a hinged cover over the storage compartment at the back of the car. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun == car_key)
        "If you close the key into the trunk you'll never leave this place any more.";
  ],
  after
  [;
    Close:
      give self locked;
      "The trunk clicks shut.";
  ],
  with_key car_key,
has container lockable locked openable scenery;

!----------------------------------------
! Kerosene can
!----------------------------------------
Object can "kerosene can" trunk
class ContainerForLiquids
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'kerosene' or 'kero' or '5-litre' or '5//' or 'litre' or 'five-litre' or 'five' or 'jerry' or 'can' or 'tin' or 'of' or 'jerrycan')
    {
      i++;
      if (nw == 'kerosene' or 'kero' && TestScope(kerosene))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "It's a 5-litre kerosene can.";
    if (self in player)
    {
      print " Judging by the weight, it's ";
      if (kerosene notin self)
        print "empty.";
      else
        print "full.";
    }
    " There's a label on the can.";
  ],
  before
  [;
    Empty, EmptyT, PourT, Pour:
      if (kerosene notin self)
        "The kerosene can is empty.";
      if (location ~= room05)
        "Don't waste the kerosene. You might need it later.";
      move kerosene to room05;
      move revolver to room05;
      move item05 to limbo;
      give larva general;
      StopDaemon(larva);
      !move strange_substance to limbo;
      !move dead_substance to room05;
      print "You pour the kerosene over the larva which immediately retracts and, in a few seconds, stops pulsating. You can now see a revolver, that the larva was previously accidentally covering. "; 
      <<Empty self>>;
    Read:
      <<Read label>>;
    Receive:
      "The can is intended for kerosene. You can't possibly put anything else into it.";
    Smell:
      if (kerosene in self)
        "It smells like kerosene.";
    Wave:
      if (kerosene in self)
        "You hear the kerosene splooshing around inside.";
  ],
  after
  [;
    Take:
      if (kerosene in self)
        "You hear something splooshing around inside the can when you pick it up.";
  ],
  size 6,
  add_to_scope label,
has container open;

!----------------------------------------
! Label on can
!----------------------------------------
Object label "label"  
with
  name 'instructions' 'label' 'warning' 'notes' 'note' 'hazards' 'risks',
  description
  [;
    "It alert users to potential hazards and risks. ";
  ],
  before
  [;
    Read:
	    "Among the rest, the label states: 'Keep out of reach of children', 'Do not disperse in the environment' and 'May pose a threat to living things'.";
  ],
  size 2,
has scenery;

!----------------------------------------
! Kerosene
!----------------------------------------
Object kerosene "kerosene" can
with
  article "some",
  name 'kerosene' 'kero',
  description
  [;
    if (self in can)
      "You can't see the kerosene while it's in the can, but you can certainly smell it.";
    else
      "It's spilled all over the place and apparently killed the creature.";
  ],
  before
  [;
    Pour, PourT, PutOn, Empty, EmptyT:
      <<Empty can>>;
    Take:
      if (self in can)
        "You can't take the kerosene out of the can, but you could empty the can if needed.";
      "Don't be silly. You can't take the kerosene once it's been poured out.";
    Smell:
      "It has a sharp, and slightly sweet, distinctive odor.";
  ],
has static;

!========================================
! Room 5: Inside Post Office
!========================================
Object room05 "Inside Post Office"
with
  description [;
    print "The inside of the post office is a mess. There are papers everywhere and dust that has blown in through the door. ";
    if (kerosene in self)
      "The larva has now gone dark.";
    "Your eyes catch a strange substance that shines with a phosphorescent light. At a second glance, it looks like an insect larva, but it's much bigger in size.";
  ],
  w_to
  [;
    if (larva hasnt general)
      StopDaemon(larva);
    return room06;
  ],
  before
  [;
    Smell: 
      if (kerosene in self)
        "The distinctive, pungent, oily, chemical odor of the kerosene fills up your nostrils.";
      "You only smell dust and decay.";
  ]
has light;

!----------------------------------------
! Post office (fake) door
!----------------------------------------
Object "door" room05
with
  name  'broken' 'door' 'opening',
  description "It's broken and cannot be opened or closed.",
has scenery;

!----------------------------------------
! Post office
!----------------------------------------
Object "post office" room05
with
  name 'post' 'office' 'mess',
  description "There are letters and parcels everywhere, as if an intense struggle had happened here.",
has scenery;

!----------------------------------------
! letters and parcels
!----------------------------------------
Object "letters and parcels" room05
with
  name 'letter' 'letters' 'parcel' 'parcels' 'packages' 'papers',
  description "The mess testifies that an intense struggle happened here, but there's nothing special about the letters or the parcels.",
has scenery pluralname;

!----------------------------------------
! Old sack
!----------------------------------------
Object sack "old sack" room05
class OpenableContainer
with  
	article "an",
  name 'old' 'sack',
	description 
	[;
		print "It's one of those sacks postmen use to retrieve and carry letters around. There's a hole in the bottom. ";
		<<Search self>>;
	],
  before 
  [;
    Take:
      if (larva hasnt general)
        "You can't take it while that strange substance is in the way.";
    Open, Close:
      if (larva hasnt general)
        "You can't do anything to it while that strange substance is in the way.";
    Receive:
      if (noun ~= dog)
        "Although you could do it, there's a hole in the sack, so you avoid putting that into it.";
    Empty:
      if (dog in sack)
      {
        if (player in room25)
        {
          StopDaemon(rats);
          move dog to room25;
          give rats general;
          "You empty the sack dropping the dead dog on the ground, and then take a couple of steps back. The rats suddenly throw themselves on the animal's carcass and begin to devour it ravenously. You are now able to proceed eastwards.";
        }
        else
        {
          move dog to location;
          "You empty the sack, dropping the dog to the ground.";
        }
      }
      else "The sack is empty.";
    Drop:
      if (dog in sack)
      {
        if (player in room25)
        {
          StopDaemon(rats);
          move sack to room25;
          move dog to room25;
          give rats general;
          "You empty the sack dropping the dead dog on the ground, drop the sack itself and then take a couple of steps back. The rats suddenly throw themselves on the animal's carcass and begin to devour it ravenously. You are now able to proceed eastbound.";
        }
        else
        {
          move sack to location;
          "You drop the sack to the ground.";
        }
      }
      else 
      {
        move sack to location;
        "You drop the sack to the ground.";
      }
  ],
  add_to_scope hole,
has container openable open;

!----------------------------------------
! Hole in sack
!----------------------------------------
Object hole "hole"
with
  name 'hole',
  description "It's big enough to prevent the sack from containing small objects. However, bigger things may possibly be put inside it.",
has scenery;

!----------------------------------------
! Larva
!----------------------------------------
Object larva "larva" room05
with
  parse_name
  [ nw i;
    nw = NextWord();
    while ((nw == 'dead' && self has general) || (nw == 'insect' or 'larva' or 'strange' or 'substance'))
    {
      i++;
      nw = NextWord();
    }
    return i;
  ],
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "It looks like an insect larva, but it's much bigger in size. ";
    if (self hasnt general)
      "It moves in a slow but aggressive way, so you'd better keep a distance.";
    else
      "The larva is now dead and seems crystallised. It no longer moves and doesn't shine any more.";
  ],
  life
  [;
    Attack:
      if (self has general)
        "There's no need to. It's dead already.";
      "You cannot attack it directly. You need to think of something different.";
  ],
  before
  [;
    Take, Touch, Search:
      "No way!";
  ],
  daemon
  [;
    self.time_left++;
    if (self.time_left > 1)
      print "^The larva";
    switch (self.time_left)
    {
      2: " is creeping toward you. Be careful.";
      3: " is now very close. It looks like you're about to get attacked.";
      4: StopDaemon(self);
        deadflag = 1;
        " rises up like a huge snake and with lightning speed springs towards your face, sticking to your skin like glue. You soon die of suffocation, while your skin is melting down.";
    }
  ],
  time_left 0,
has animate neuter;

!----------------------------------------
! Luminous halo surrounding the strange substance
!----------------------------------------
Object item05 "light" room05
with
  name 'phosphorescent' 'light',
  description "It has a weird appearance, and it gives the larva a sinister look.",
has scenery;

!----------------------------------------
! Revolver
!----------------------------------------
Object revolver "revolver"
with
  name 'revolver' 'handgun' 'pistol' 'gun' 'guns//p' 'weapon' 'weapons//p' 'single-action' 'single' 'action' '45' 'calibre',
  description
  [;
    print "It's a single-action revolver. It's currently ";
    if (bullets.number == 0)
      "empty.";
    print "loaded with ", bullets.number, " bullet";
    if (bullets.number > 1)
      print "s";
    ".";
  ],
  before
  [;
    Load:
      "It's already loaded with ", bullets.number, " bullets and you don't have any more.";
  ],
  add_to_scope bullets,
has;

!----------------------------------------
! Bullets
!----------------------------------------
Object bullets "bullets"
with
  name 'bullet' 'bullets' 'ammo',
  description
  [;
    if (self.number == 0)
      print_ret (string)REVOLVER_IS_EMPTY;
    print "There are ", self.number, " bullet";
    if (self.number > 1)
      print "s";
    " in the revolver.";
  ],
  before
  [;
    Take:
      if (self.number == 0)
        print_ret (string)REVOLVER_IS_EMPTY;
      print "Leave the bullet";
      if (self.number > 0)
        print "s";
      " in the revolver in case you need them.";
  ],
  number 6,
has pluralname scenery;

!========================================
! Room 6: Town Square
!========================================
Object room06 "Town Square"
with
  description "You have now reached a square. It's rather small, as the entire town is, but it was clearly meant as a pivoting point. Seeing it so empty gives you an eerie feeling. The road crossing it proceeds south to north, but you can also go east or west.",
  n_to
  [;
    if (dog hasnt general)
    {
      dog.time_left = 0;
      StartDaemon(dog);
    }
    return room10;
  ],
  e_to
  [;
    if (larva hasnt general)
    {
      larva.time_left = 0;
      StartDaemon(larva);
    }
    return room05;
  ],
  !w_to room07,
  w_to "The western exit leads to an inn, but there's no way to get inside since it has been wrecked. You decide not to bother with it, since you need to fix your car and find your cousin.",
  s_to room03,
has light;

!----------------------------------------
! Inn
!----------------------------------------
Object "inn" room06
with
  name 'small' 'village' 'inn' 'tavern',
  description "You're guessing it's an inn, but it's possibly a tavern. It's hard to tell, as you have no time to enter it and check.",
has scenery;

!----------------------------------------
! Town square
!----------------------------------------
Object "square" room06
with
  name 'square',
  description "The square is not very big, but it looks beautiful. Actually, it would look beautiful under different circumstances. It has exits in every direction.",
has scenery;

!========================================
! Room 7: Village Inn
!========================================
! removed from game

!========================================
! Room 8: Small Sacristy
!========================================
Object room08 "Small Sacristy"
with
  description "You're in the small sacristy behind the village church. The furniture inside the narrow room is smashed and, among the confusion, you see the corpse of a man, horribly disfigured. You can also see some strange equipment. The only way out is via the door towards the west.",
  w_to sac_door,
has light;

!----------------------------------------
! Small sacristy
!----------------------------------------
Object sacristy "small sacristy" room08
with
  name 'small' 'sacristy',
  description "The small sacristy is compact and functional. It is used to serve as a private preparation area for clergy and storing sacred items, but it's now an alien installment.",
has scenery;

!----------------------------------------
! Corpse
!----------------------------------------
Object dead_body "dead body" room08
class Body
with
  article "a",
  parse_name
  [ i;
    while (NextWord() == 'dead' or 'body' or 'corpse' or 'man')
      i++;
    return i;
  ],
  description "The man is dressed in fine garments. However, those expensive clothes are of no use any more. The corpse is horribly disfigured and those larvae must have something to do with it.",
  before
  [;
    Search:
      "Please leave this poor thing alone.";
  ],
has animate;

!----------------------------------------
! suit
!----------------------------------------
Object garments "garments" room08
with
	name 'expensive' 'garments' 'clothes',
	description	"They look very expensive.",
  before
  [;
    Take:
      "Please show some respect. Besides, you wouldn't know what to do with them.";
  ]
has scenery pluralname;

!----------------------------------------
! Strange equipment similar to an incubator, in which you glimpse monstrous larvae
!----------------------------------------
Object alien_equipment "strange equipment" room08
with
  name 'strange' 'alien' 'equipment' 'incubator' 'machine',
  description "The strange equipment is similar to an incubator, in which you glimpse monstrous larvae. They are pulsating and moving slowly.",
  before 
  [;
    Attack:
      if (axe notin player)
        "I wouldn't do that bare-handed.";
      move alien_equipment to limbo;
      move monstrous_larvae to limbo;
      move destroyed_equipment to location;
      move larvae_remains to location;
      give destroyed_equipment general;
      "Using your axe, you smash the equipment until you destroy it all and kill the larvae.";
  ],
has scenery;

!----------------------------------------
! The monstrous larvae
!----------------------------------------
Object monstrous_larvae "monstrous larvae" room08
with
  name 'monstrous' 'larvae',
  description "They must be the source of the infection. If you were to make an educated guess, you would say these monstrous larvae are ready to infect their host. They are pulsating and moving slowly. You'd better destroy the equipment before it's too late.",
has scenery;

!----------------------------------------
! Destroyed equipment among which you can see the remains of monstrous larvae
!----------------------------------------
Object destroyed_equipment "destroyed alien equipment"
with
  article "the",
  name 'alien' 'destroyed' 'equipment',
  description "You smashed it all, and you can see the remains of monstrous larvae inside. Is this the end?",
  before
  [;
    Attack:
      "There's nothing to be destroyed, any more.";
  ],
has static;

!----------------------------------------
! remains of monstrous larvae
!----------------------------------------
Object larvae_remains "remains of monstrous larvae" 
with
  article "some",
  name 'remains' 'of' 'monstrous' 'larvae',
  description "They won't hurt anyone any more.",
has scenery;


!----------------------------------------
! Document to unveil the truth
!----------------------------------------
Object letter "letter" room08 
with
  name  'letter' 'sheet' 'of' 'paper' 'document',
  description
  [;
    if (self hasnt general)
      "Yet another document. You hope to finally discover the truth, here.";
    "It's a document explaining the truth. ";
  ],
  before
  [;
    Read:
	    if (self in player)
      { 
        give self general;
        print "'They came a few years ago, and they offered me a way out of my misery. I don't know where they are now, but they cured me and offered me wellness and power. The only thing they wanted from me in return was to grow these larvae and release them in the environment when told to do so. If I only had known...'^^Who is this guy? Judging from the fine garments he's wearing, he must be a wealthy one. The mayor, perhaps? You keep on reading.^^'I tried to destroy the equipment but they surprised me, infected me, and left me for dead locked inside this room. Those aliens were leaving the town, but they must be hiding somewhere...'^^Then, the writing becomes unreadable. ";
        if (alien_equipment in location)
          "It's better to take care of this equipment, now.";
        "You have nothing else to do here.";
		  }
      else "But you are not holding the document.";
  ],
  size 2,
has;

!----------------------------------------
! Door to sacristy (floating object)
!----------------------------------------
Object sac_door "sacristy door"
with
  name 'barred' 'sacristy' 'door',
  description
  [;
    print "It's the door that leads to the sacristy. It's currently ";
    if (self has open)
      "open.";
    print "closed";
    if (self has locked)
      print " and locked from the other side. An intense brightness filters through its gaps.";
    "";
  ],
  door_dir
  [;
    if (self in room09)
      return e_to;
    else
      return w_to;
  ],
  door_to
  [;
    if (self in room09)
      return room08;
    else
      return room09;
  ],
  before 
  [;
    Open:
      if (self has open)
        "You chopped it into pieces already.";
    Close:
      if (self has open)
        "It's impossible to close it now that you've chopped it down to splinters.";
    Lock, Unlock:
      "You don't have the key.";
    Touch:
      "I wouldn't do it, if I were you. It might be dangerous.";
    Attack:
      if (axe in player)
      {
        if (side_b hasnt general)
          "As soon as you start hitting the door, impressive bolts of energy erupt from the cracks, enveloping you and lifting you into the air, sending you across the church. You are lucky to be still alive.";
        if (self hasnt general)
        {
          give self general;
          give self ~locked;
          give self open;
          move gaps to limbo;
          "You hit the door with all your might, until you finally open a way. You can now enter the sacristy.";
        }
        else
          "You'll already opened a way through.";
      }
      "As you approach the door without anything suitable to force it open, a flash of bright light blinds you and you are hit by an intense (and very painful) discharge of energy. You need to think of something else.";
  ],
  with_key dummy_key,
  found_in room08 room09,
has door openable lockable locked scenery;

!========================================
! Room 9: Church
!========================================
Object room09 "Church"
with
  description 
  [;
    print "The interior of the church is wrapped in a deep silence, but the atmosphere you breathe is soothing and relaxing. For a brief moment it makes you forget all the evil that awaits you outside. You can return to the streets by going west, while a ";
    if (sac_door has locked)
      print "barred ";
    else
      print "broken ";
    "door to the east leads to the sacristy.";
  ],
  w_to
  [;
    if (dog hasnt general)
    {
      dog.time_left = 0;
      StartDaemon(dog);
    }
    return room10;
  ],
  e_to sac_door,
has light;

!----------------------------------------
! Church
!----------------------------------------
Object "church" room09
with
  name 'old' 'country' 'church',
  description "This old country church seems almost out of place in this town, but you like how it blends with a more modern architecture.",
  found_in room09 room10,
has scenery;

!----------------------------------------
! Intense brightness that filters through the gaps of the barred door
!----------------------------------------
Object intense_brightness "intense brightness that filters through the gaps in the sacristy door" room09
with
  article "an",
  name 'intense' 'brightness',
  description "It is very bright, and filters through the small gaps in the sacristy door.",
has static;

!----------------------------------------
! Gaps in the barred door
!----------------------------------------
Object gaps "gaps" room09
with
  article "some",
  name 'gaps',
  description 
  [;
    if (intense_brightness notin limbo)
      "They are big enough to let an intense brightness filter through them.";
    "Now that you disabled the security system the light doesn't filter through the gaps any more.";  
  ],
  before
  [;
    Touch:
      "I wouldn't do it, if I were you. It might be dangerous.";
    Attack:
      "Actually, it's the door you should try to open, not the gaps.";
  ],
has scenery pluralname;

!========================================
! Room 10: Road
!========================================
Object room10 "Road"
with
  description "The road winds through the buildings of Creek Town extending from south to north. You can see a funeral home on the west side and a church on the east side.",
  !n_to "You can't go north, since a rabid dog is blocking the way.", 
  !s_to room06,
  n_to
  [;
    if (dog hasnt general)
      "The dog is blocking your way.";
    else
      return room14;
  ],
  s_to
  [;
    if (dog hasnt general)
      StopDaemon(dog);
    return room06;
  ],
  e_to
  [;
    if (dog hasnt general)
      StopDaemon(dog);
    return room09;
  ],
  w_to 
  [;
    if (dog hasnt general)
      StopDaemon(dog);
    return room11;
  ],
  in_to 
  [;
    if (dog hasnt general)
      StopDaemon(dog);
    return room11;
  ],
  before
  [;
    Hint:
      if (dog hasnt general)
        "In case of emergency, a weapon can help to solve the situation.";
  ],
has light;

!----------------------------------------
! dog
!----------------------------------------
Object dog "dog" room10
with
  name 'dog',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "It's just a dog like many others, and there's nothing special about it. ";
    if (self hasnt general)
      "Yet, despite its small size, it's barking furiously, as if it were rabid. You'd better keep a distance.";
    else
      print"However, this one won't be doing any more barking, as it's dead";
      if (self in room25)
        print" and just became the main course for those rats";
      ".";
  ],
  life
  [;
    Attack:
      if (self hasnt general)
        "You can't attack it up close or it could bite you and possibly infect you. ";
      else
        "Don't waste your time. It's already dead.";
  ],
  before
  [;
    Eat:
      if (self hasnt general)
        "It's more likely that the dog will eat you.";
    Shoot:
      if (CantBeShot())
        rtrue;
      if (self has general)
        print_ret "It's", (string)ALREADY_DEAD;
      bullets.number = 0;
      give self general;
      move dead_larva to room10;
      StopDaemon(self);
      "BANG! You shoot the dog just as it's about to pounce and it falls to the ground, dead. You were not prepared to witness what happens next. A huge larva bursts out of the dog's body and, screaming in terror, you empty your revolver into it.";
    Take:
      if ((self in room25) && (rats has general))
      {
        self.take_attempts++;
        if (self.take_attempts < 2)
          "The rats are feasting on the dead dog. If you want to become their next meal please go ahead.";
        else 
        {
          deadflag = 1;
          "The rats launch themselves at you, biting you in various parts of your body. You struggle desperately to get them off, and you actually manage to detach a few, but their number is overwhelming and, in a few minutes, your are doomed.";
        }
      }
      if (self hasnt general)
        "That dog would bite you at least a couple of times before you have a chance to take it.";
      if (sack notin player)
        "You don't know what infected the dog. It might be wiser to put it inside something, if you need to carry it around with you.";
      if ((sack in player) && (dog notin sack))
      {
        move dog to sack;
        "Using it as if it were a glove, you put the sack over the dog, then pick up the sack, thus avoiding ever touching the animal.";
      }
    Drop, Give:
      if ((dog in sack) && (sack in player))
      {
        if (player in room25)
        {
          StopDaemon(rats);
          move self to room25;
          give rats general;
          "You drop the dead dog on the floor, and then take a couple of steps back. The rats suddenly throw themselves on the animal's carcass and begin to devour it ravenously. You are now able to proceed eastbound.";
        }
        else
        {
          move dog to location;
          "You empty the sack, dropping the dog to the ground.";
        }
      }
    Touch, Search:
      "You'd better not!";  
  ],
  daemon
  [;
    self.time_left++;
    print "^The dog";
    switch (self.time_left)
    {
      1: " stares at you with bloodshot eyes and foam at the mouth. Be careful.";
      2: "'s posture is changing and getting more aggressive.";
      3: " is creeping towards you. It's now very close. It looks like you're about to get bitten, and possibly infected.";
      4: StopDaemon(self);
        deadflag = 1;
        " lunges at you, biting your throat. You try in vain to do something to stop it, but now you can no longer avoid a horrible death.";
    }
  ],
  time_left 0,
  take_attempts 0,
has animate neuter;

!----------------------------------------
! Road (floating object)
!----------------------------------------
Object town_road "town road"
with
  name 'road',
  description "It's the road that runs south to north inside Creek Town.",
  found_in room06 room10 room14,
has scenery;

!----------------------------------------
! Dead larva
!----------------------------------------
Object dead_larva "dead larva" 
with
  name 'dead' 'larva',
  description "Apparently this horrific thing was inside the dog, driving it mad. It's disgusting. It left a green slime trail when it bursted out from the dog.",
  life
  [;
    Attack:
      "Don't waste your time. It's already dead.";
  ],
  before
  [;
    Eat:
      "What? I mean... really?";
    Shoot:
      "You already did. At least 5 times.";
    Take:
      "No, thanks.";
    Touch:
      "I know it's dead, but have you seen what it has done to the dog?";
  ],
has animate neuter;

!----------------------------------------
! Slimy trail
!----------------------------------------
Object slimy_trail "green slimy trail" room10
with
  name 'green' 'slimy' 'slime' 'trail',
  description "It's disgusting.",
  before
  [;
    Touch, Take:
      "I dont' think so.";
    Smell:
      "It smells horrible.";
  ],
has scenery;

!========================================
! Room 11: Funeral Home
!========================================
Object room11 "Funeral Home"
with
  description "The inside of the funeral home is well decorated, but what makes it stand out is the large coffin that lies in the centre of the room. Since you are not in Transylvania, you doubt it can host a vampire, but it still makes you feel uncomfortable. When you are done here, you can return to the street by heading east.",
  e_to
  [;
    if (dog hasnt general)
    {
      dog.time_left = 0;
      StartDaemon(dog);
    }
    return room10;
  ],
  out_to
  [;
    if (dog hasnt general)
    {
      dog.time_left = 0;
      StartDaemon(dog);
    }
    return room10;
  ],
has light;

!----------------------------------------
! Funeral home interior
!----------------------------------------
Object "interior" room11
with
  name 'interior' 'inside',
  description "The interior is designed for comfort, peace and support. It features calming, neutral colours, soft lighting, plush seating and natural elements, like plants or wood, to create a serene, homely sanctuary for grieving families. ",
has scenery;

!----------------------------------------
! Funeral home decorations
!----------------------------------------
Object "decorations" room11
with
  name 'decorations' 'decore',
  description "They mainly consists of plants, candles and soothing pictures. ",
has scenery;

!----------------------------------------
! Funeral home decoration details
!----------------------------------------
Object "detail" room11
with
  name 'plants' 'candles' 'soothing' 'pictures',
  description "They are thought to create a serene, homely sanctuary for grieving families, but there's nothing special about them. ",
has scenery;

!----------------------------------------
! Funeral home (floating object)
!----------------------------------------
Object "funeral home" 
with
  name 'funeral' 'home',
  description "It's a homely sanctuary for grieving families. ",
  before
  [;
    Enter:
      if (self in room10)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room11)
        <<Go FAKE_OUT_OBJ>>;
  ],
  found_in room10 room11,
has scenery;

!----------------------------------------
! Coffin
!----------------------------------------
Object coffin "coffin" room11
class OpenableContainer
with
  name 'coffin' 'luxurious' 'looking',
  description
  [;
    print "It's a very luxurious coffin, made with high-quality wood";
    if (self has open)
      print "  and silk padding";
    print ". ";
    if (self hasnt open)
      "The coffin is closed.";
    <<Search self>>;
  ],
  before
  [;
    Close:
      if (self hasnt open)
        "It's already closed.";
      give self ~open;
      "You close the coffin.";
    Lock:
      "That's not something you can lock.";
    Open:
      if (self has open)
        "It's already open.";
      give self open;
      print "You open the coffin. ";
      <<Search coffin>>;
    Pull, Push, Take:
      print_ret (string)TOO_HEAVY_TO_MOVE;
    Unlock:
      "That's not something you can unlock.";
  ],
  size 10,
has container openable scenery;

!----------------------------------------
! Coffin wood
!----------------------------------------
Object "coffin wood" room11
with
  name 'high-quality' 'wood',
  description "It's smooth and warm to the touch. ",
  before
  [;
    Touch:
      "You touch the wood of the coffin, and automatically say a prayer for the poor man. What and unfortunate fate.";
  ],
has scenery;

!----------------------------------------
! Coffin padding
!----------------------------------------
Object "coffin padding" room11
with
  name 'silk' 'satin' 'padding',
  description "It look very expensive. ",
  before
  [;
    Touch:
      "Unlike the wood, the silk feels smooth but cold.";
  ],
has scenery;

!----------------------------------------
! vial of poison
!----------------------------------------
Object vial "vial" coffin
with
  name 'vial',
  description
  [;
    if (self hasnt general)
        give self general;
    "You have no way to be sure of this, but the vial probably contained some poison. That would explain its presence inside the coffin. ";    
  ],
  before
  [;
    Take:
      "You don't need it, and aren't sure about its content. It's better to leave it where it is.";
    Touch:
      "You'd better not.";
    Smell:
      "You lean inside the coffin trying to smell the content of the vial, but that 'scent of bitter almonds' everyone talks about has probably faded away.";
  ],
has static;

!----------------------------------------
! Owner's body
!----------------------------------------
Object owners_body "body" coffin
class Body
with
  article "a",
  name 'body' 'human',
  description
  [;
    print "It's likely the corpse of the funeral home's owner. Since you are not a coroner, you have no idea what the cause of the death was, but ";
    if (vial has general)
      print "he could have poisoned himself just to escape this nightmare. ";
    else 
      print "the vial could have something to do with it. ";
    if (self hasnt general)
      "It might be worth searching him.";
    else 
    {
      give self general;
      print_ret (string)SEARCH_AGAIN;
    };
  ],
  before
  [;
    Search:
      print "You search the man's pockets ";
      if (house_key in nothing)
      {
        move house_key to player;
        move note to player;
        scope_modified = true;
        "and find a key and a note. You take them and put them in your inventory.";
      }
      print_ret (string)SEARCH_AGAIN;
  ],
has animate;

!----------------------------------------
! House key
!----------------------------------------
Object house_key "house key" 
with
  name 'brass-coated' 'brass' 'house' 'key',
  description "It's a brass-coated key, the kind of key you would use for a house door.",
has;

!----------------------------------------
! Owner's note
!----------------------------------------
Object note "note"  
with
  name 'note',
  description
  [;
    "It's a note, written on stationary with the funeral home's letterhead. ";
  ],
  before
  [;
    Read:
	    if (self hasnt general)
        give self general;
      if (self in player)
      { 
        "'Ever since that night, things have gone wild here, and it's scary. That night ... when I saw that bright light falling from the sky and disappearing into the woods.^^I started to investigate, but the town's higher-ups prohibited it. And, after that, everything started to change. Strange lights and sounds in the night; electric equipment malfunctioning; people gone missing.^^I can't take it any more, so I decided to end it here. I left another note hidden somewhere else in town; search, and you may find it.'^^So Alan wasn't lying about this. What's going on, here?";
		  }
      else "But you are not holding the document.";
  ],
  size 2,
has;

