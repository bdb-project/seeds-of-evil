!----------------------------------------
! Armed looters
!----------------------------------------
Object looters "couple of armed looters" room15
with
  name 'couple' 'of' 'armed' 'looters',
  initial 
  [;
    if (looters hasnt general)
      "A couple of looters are inside the shop.";
    "Thanks to your 'excellent' aim, the two looters are now harmless.";
  ],
  description
  [;
    if (looters hasnt general)
      "The two looters are intent on scavenging the place, and are not paying attention to you. You notice that they are cradling rifles in their arms, so they are likely to be very dangerous. ";
    else
      "They now lie on the ground unconscious.";
  ],
  life
  [;
    Ask, Talk:
      print "Asking things to those men would only get you killed. ";
      if (looters has general)
        "Besides, they now lie on the ground unconscious; I doubt they would be very responsive.";
    Attack:
      if (looters hasnt general)
        "Indeed! But you need to be more specific.";
      "Since they are already lying on the ground unconscious, I suppose there's no need to.";
    Give, Show:
      if (looters hasnt general)
        "This move would only get you killed.";
      "Since they are lying on the ground unconscious, I suppose they are not very interested.";
  ],
  before
  [;
    Shoot:
      if (second == revolver && revolver notin player)
        "You're not holding the revolver.";
      if (second == revolver && revolver in player)
        "The revolver is empty. What if the looters don't buy your bluff?";
      if (shotgun notin player)
        "Those looters seem used to fighting. You'll need a bigger, more powerful weapon to get rid of them.";
      if (shotgun in player)
      {
        if (shotgun.number == 0)
        {
         deadflag = 1;
         "You realize you never loaded the shotgun, so those looters have all the time to take aim and hit you in the middle of the forehead with a precise rifle shot.You fall to the ground, dead. What an ugly way to end your days!";
        }
        else
        {
          StopDaemon(self);
          shotgun.number = 0;
          give self general;
          move battery to room15;
          move shelf to room15;
          "BANG! You shoot the first round and the recoil sends you across the shop. You obviously miss the target, but manage not to get killed either.^^BANG! You shoot again, and again you miss the looters. Yet, you hit a shelf which, with a loud noise, breaks down and fortuitously hits them. As they are lying on the ground unconscious, you can now take a look around.";
        }
      }
  ],
  daemon
  [;
    self.time_left++;
    print "^The couple of looters ";
    switch (self.time_left)
    {
      1: "are searching through the mess and they don't notice you.";
      2: "are now getting closer. You'd better think of something.";
      3: "are now very close and may see you at any moment. Either do something or leave the place.";
      4: StopDaemon(self);
        deadflag = 1;
        "see you, and immediately raise their rifle and fire at you! Your lifeless body falls to the ground. Your adventure ends here.";
    }
  ],
  time_left 0,
has animate neuter pluralname transparent;

