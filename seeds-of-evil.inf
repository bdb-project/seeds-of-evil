! NEW Room 13 (former 27): Small Garage
!========================================
Object room13 "Small Garage"
with
  description "The small garage houses an old car covered in dust and full of dents. When you are done here, you can leave towards the west.",
  out_to room14,
  w_to room14,
has light;

!----------------------------------------
! Small garage
!----------------------------------------
Object "garage"
with
  name 'small' 'garage' 'construction',
  description "It's a small construction that barely holds a car. You wonder where the residents park their vehicles.",
  found_in room13 room14,
has scenery;

!----------------------------------------
! Big car
!----------------------------------------
Object big_car "car" room13
	with name 'big' 'dusty' 'old' 'car' 'dents',
		description "A big dusty and dented car is parked here. As a matter of fact, it's so big that you don't have enough space to open its doors to get in. You wonder how they fit it inside the garage. The hood of the car is open.",
		before [;
			Open:
        "Even if you had the key, there's not enough room to open the door.";
      Enter: 
				"There's no enough room to open the door, so you cannot enter it.";
			],
	has scenery container;

!----------------------------------------
! Hood
!----------------------------------------
Object big_hood "hood" room13
with
  name 'hood',
  description
  [;
    print "It's a hinged cover over the engine bay. ";
    <<Search self>>;
  ],
  before
  [;
    Open: 
      "It is open already.";
    Close:
      "As you cannot enter the car to reach its controls, you'd better not close it. You wouldn't be able to open it again.";
  ],
has container openable open scenery;

!----------------------------------------
! Engine
!----------------------------------------
Object big_engine "V8 engine" big_hood
with
  name 'v8' 'engine',
  description "It's a V8 engine similar to the one in your car.",
  before
  [;
    SwitchOff, SwitchOn:
      "It might be easier to do that if you're in the car.";
  ],
has static;

!----------------------------------------
! Working car spark plug
!----------------------------------------
Object working_plug "working spark plug" big_hood
with
  !name 'working' 'spark' 'plug',
  parse_name
  [ nw;
    nw = NextWord();
    if (nw == 'working')
    {
      nw = NextWord();
      if (nw == 'plug')
        return 2;
      else 
        if (nw == 'spark' && NextWord() == 'plug')
          return 3;
    }
    if (nw == 'spark')
      if (NextWord() == 'plug')
        return 2;
    if (nw == 'plug')
      return 1;
    return 0;
  ],
  description "It's brand new and the size you need.",
  before
    [;
      Replace, Transfer:
        if (player in room29)
        {
          if (hood hasnt open)
            "It's a little difficult to replace the plug if the hood isn't open.";
          if (self in hood)
            "You've already replaced it.";
          <<Replace spark_plug>>;
        }
        if (player in room13)
          "You only need to take this plug. It's the one in your car that you have to replace.";
        "How do you propose to do that from a distance?";
      Insert:
        if (second == car or engine or hood)
          <<Replace spark_plug>>;
        else "There's no need to put it back.";
      Take:
        if (self in big_hood)
          "You cannot just take it, since it's tightly screwed.";
        if (self in hood)
          "You risked your life more than once to get that new spark plug. Why would you want to remove it now?";  
      Screw:
        if (self hasnt moved)
          "The spark plug is already screwed in. Maybe you should try unscrewing it.";
        "You obtained what you needed; there's no point in putting it back.";
      Spray:
        if (second == nothing && wd40 in player)
        {
          print "(with the WD-40)^";
          <<Spray self wd40>>;
        }
        if (second == nothing)
          "You'll have to tell me what to ", (address)verb_word, " it with.";
        if (second ~= wd40)
          "You can't ", (address)verb_word, " them with ", (ThatOrThose)second, ".";
        give self general;
        "You spray the spark plug with the WD-40. If the claims on the can are true, you should now be able to unscrew it.";
      Unscrew:
        if (self hasnt moved)
        {
          if (second == nothing && pliers in player)
          {
            print "(with the pliers)^";
            <<Unscrew self pliers>>;
          }
          if (second == nothing)
            "You'll have to tell me what to unscrew it with.";
          if (second ~= pliers)
            "You can't unscrew it with ", (ThatOrThose)second, ".";
          if (self hasnt general)
          {
            "The spark plug is too tight. It may have been rusted by the damp air from the countryside. You'll have to loosen it somehow.";
          }
          move self to player;
          scope_modified = true;
          "You unscrew the spark plug and put it in your inventory.";
        }
        else "You've already unscrewed the plug.";
  ],
has;

!========================================
! Room 14: Road
!========================================
Object room14 "Road"
with
  description [;
    print "The long asphalt road crosses the town from north to south. You can also see a shop towards the west and a garage to the east. Access to the garage is granted through a roller shutter, which ";
    if (item37 hasnt general)
      "is currently closed.";
    "is now all the way up.";
  ],
  n_to room20,
  s_to room10,
  e_to "You cannot venture east because the roller shutter is closed.",
  w_to
  [;
    if (looters hasnt general)
    {
      looters.time_left = 0;
      StartDaemon(looters);
    }
    return room15;
  ],
  in_to
  [;
    if (looters hasnt general)
    {
      looters.time_left = 0;
      StartDaemon(looters);
    }
    return room15;
  ],
has light;

!----------------------------------------
! Roller shutter
!----------------------------------------
Object item37 "roller shutter"
with
  name 'rusty' 'roller' 'shutter' 'shutters',
  description [; 
    print"It's a metallic roller shutter that allows the owner to open and close the garage. It was probably meant to offer enhanced security by blocking any attempted break-in of intruders. ";
    if (self hasnt general)
      "The locking mechanism has been broken, yet the shutter is still closed. The rust may have stuck it.";
    "The shutter is now open and you can go in the garage.";
  ],
  before
  [;
    Take: 
      "You cannot take the shutter.";
    Lower:
      if (self hasnt general)
        "It's already all the way down, so it can only be raised.";
      "It's now all the way up. Leave it as it is.";
    Push, Pull:
      "The shutter can't be pushed or pulled. Try raising or lowering it instead.";
    Open, Raise:
      if (self hasnt general)
        "It's completely rusty.";
      "It's now all the way up. Leave it as it is.";
    Spray:
        if (self has general)
          "You already sprayed the shutter, and now it's completely open.";
        if (second == nothing && wd40 in player)
        {
          print "(with the WD-40)^";
          <<Spray self wd40>>;
        }
        if (second == nothing)
          "You'll have to tell me what to ", (address)verb_word, " it with.";
        if (second ~= wd40)
          "You can't ", (address)verb_word, " them with ", (ThatOrThose)second, ".";
        give self general;
        room14.e_to = room13;
        "You spray the shutter with the WD-40 a few times, until you are finally able to raise it all the way up. You can proceed east towards the garage.";
  ],
  add_to_scope mechanism,
  found_in room13 room14,
has scenery;

!----------------------------------------
! Locking mechanism
!----------------------------------------
Object mechanism "broken locking mechanism"
with
  name 'broken' 'locking' 'mechanism',
  description "It's the mechanism that allowed to lock the shutter. It has been broken and doesn't work.",
has scenery;

!========================================
! Room 15: Small Shop
!========================================
Object room15 "Small Shop"
with
  description "The chaos that reigns in this shop is beyond words. Broken glass, dust and objects are scattered everywhere. The only exit is towards the east.",
  e_to
  [;
    if (looters hasnt general)
      StopDaemon(looters);
    return room14;
  ],
  out_to
  [;
    if (looters hasnt general)
      StopDaemon(looters);
    return room14;
  ],
  before
  [;
    Hint:
      if (looters hasnt general)
        "In case of emergency, a weapon can help to solve the situation.";
    Search:
      if (looters hasnt general)
        "Not while those two looters are still looting.";
  ],
has light;

