    Enter:
      if (verb_word == 'sit')
        "You sit on the bed to try it. Yep, it sure is comfy, but you have no time to waste sitting around on someone else's bed, so you stand up again.";
      if (verb_word == 'stand')
        "The bed might be all messed up, but that doesn't mean you can stand on it in your dirty boots.";
      <<Sleep>>;
    LookUnder:
      "You take a look under the bed, but there luckily are no larvae hiding there.";
  ],
