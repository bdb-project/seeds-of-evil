!----------------------------------------
! Corpse of a woman
!----------------------------------------
Object woman "corpse of a woman" room23
class Body
with
  article "the",
  name 'corpse' 'of' 'woman' 'body',
  description "The corpse of a woman lies in the dark, sitting on the floor against a wall.",
  before
  [;
    Search:
      if (self hasnt general)
      {
        give self general;
        move cabinet to room23;
        "You search the corpse but find nothing of interest. Still, you notice that the corpse's right arm points towards a corner. Now that your eyes are adjusting to the dark, you can see a filing cabinet.";
      }
      else
        "The poor thing doesn't hold anything useful to you.";
  ]
has animate female;

