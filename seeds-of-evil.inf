!========================================
Object room30 "Behind Your Car"
with
  description "You're at the rear of your car, looking over the trunk. The road continues to the north and south, while only bushes can be seen towards the west.",
  s_to "It's miles to the nearest town. Besides, you need to reach your cousin first.",
  n_to
  [;
    if (trunk has open)
      "You may want to close the trunk first, since you don't know who loiters around here.";
    return room04;
  ],
  e_to
  [;
    if (trunk has open)
      "You may want to close the trunk first, since you don't know who loiters around here.";
    return room03;
  ],
  before
  [;
    Listen:
      "Only silence can be heard.";
  ],
has light;

!----------------------------------------
! Back of car
!----------------------------------------
Object back "back of your car"
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'back' or 'rear' or 'of' or 'your' or 'car')
    {
      i++;
      if (nw == 'car' && TestScope(car))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    "There's nothing special about it, except that it's dented and battered. ";
    !<<Search self>>;
  ],
  found_in room04 room30,
