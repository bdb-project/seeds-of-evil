!PunyInform constants
Constant CUSTOM_ABBREVIATIONS;
Constant OPTIONAL_PRINT_SCENERY_CONTENTS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_PROVIDE_UNDO;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_WAIT_DEFAULT "Time passes...";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

!Game-specific constants
Constant ALREADY_DEAD " already dead, so don't waste your ammo.";
Constant REVOLVER_IS_EMPTY "The revolver is empty.";
Constant SEARCH_AGAIN "again, but don't find anything else of interest.";
Constant TOO_HEAVY_TO_MOVE "It's too heavy for you to move.";
Constant YOULL_HAVE_TO_EMPTY "You'll have to empty ";
Constant YOULL_HAVE_TO_TELL_ME_WHAT_TO "You'll have to tell me what to ";

!Replaced actions
Replace _UpdateDarkness;
Replace GoSub; !Delete if diagonal directions are used
Replace LockSub;
Replace UnlockSub;

Property size 100;

Include "globals.h";

!Game-specific variables

!========================================
! Entry point routines
!========================================
[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

[ PrintVerb word;
  if (word == ',eject')
  {
    print "eject";
    rtrue;
  }
  if (word == ',play')
  {
    print "play";
    rtrue;
  }
  if (word == ',rewind')
  {
    print "rewind";
    rtrue;
  }
  rfalse;
];

[ UnknownVerb word;
  if (word == 'eject')
    return ',eject';
  if (word == 'play')
    return ',play';
  if (word == 'rewind')
    return ',rewind';
  return false;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  lookmode = 2;
! move CARRIED to player;
  no_implicit_actions = true;
  player.description = "You are Murray Shannon, and you just reached the small settlement of Creek Town in search of your cousin Alan. You need to fix your car, and then search for him.";
  location = room28;
  ! PROLOGUE
  "^Quite unexpectedly, you received a telegram from your cousin Alan. A few years had passed since you last talked to him. It turns out that he now lives in Creek Town, a small settlement in the southern part of Louisiana. In his telegram, Alan warned about a looming danger so grave that it could affect thousands of people.^^Now Alan was known to have had mental health issues in the past, so you didn't know what to make of this. Worried about the health of the cousin you hadn't seen in a while, you decided to pack your bags and pay him a visit.^^As you approach the edge of town, your car develops electric problems and you are forced to stop at the local service station to get it seen to. You hope you can meet Alan while it is getting fixed and, in the meanwhile, uncover the truth about the looming danger that he alluded to.^";
];

!========================================
! Classes
!========================================
Class Body
with
  life
  [;
    Ask:
      "You're not likely to get an answer from a lifeless body.";
    Attack, ThrowAt:
      "Show some empathy. Allow the dead to rest in peace.";
    Give:
      "Dead bodies aren't normally in the habit of accepting gifts.";
    Kiss:
      "Eww, gross.";
    Show:
      "The dead body shows no interest in ", (the)noun, ". I wonder why.";
    Talk:
      "You strike up a one-sided conversation with the dead body, but it's bored to death.";
    Tell:
      "The corpse listens intently to what you have to say. Or maybe it's not listening at all. It's hard to tell.";
    WakeOther:
      "You give ", (the)noun, " a shake, but it doesn't respond.";
  ],
  before
  [;
    Pull, Push, Take:
      "As far as you know, this is a crime scene. Try not to alter it any more than necessary.";
  ],
has animate;

Class Liquid
with
  before
  [;
    Pour:
      if (parent(self) notin player)
      {
        print "(first taking ", (the)parent(self), ")^";
        move parent(self) to player;
      }
      if (parent(self) has container)
        <<Empty (parent(self))>>;
    Insert, PourT:
      if (second == parent(self))
        "The ", (name)self, " is already in ", (the)second, ".";
      if (second in player)
      {
        print "(first dropping ", (the)second, ")^";
        move second to location;
      }
      if (parent(self) notin player)
      {
        print "(first taking ", (the)parent(self), ")^";
        move parent(self) to player;
      }
      if (second has container)
        <<EmptyT (parent(self)) second>>;
    Take:
      print "You can't take ", (the)noun, " out of ", (the)parent(self), ", but you could ";
      if (parent(self) has scenery or static)
        "put it in a container.";
      else
        "pour it out or pour it onto something.";
  ],
has;

Class ContainerForLiquids
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt transparent || child(self) == 0))
      rtrue;
  ],
  before
  [;
    Empty:
      if (child(self) == 0)
        print_ret (The)self, " is already empty.";
      noun = child(self);
      remove noun;
      "You empty ", (the)self, " and ", (the)noun, " soaks into the ground.";
    EmptyT:
      if (noun == second)
        "You can't empty ", (the)self, " into itself.";
      if (child(self) == 0)
        print_ret (The)self, " is already empt
        y.";
      if (child(second) ~= 0)
        print_ret (string)YOULL_HAVE_TO_EMPTY, (the)second, " first.";
      if (second in player)
      {
        print "(first dropping ", (the)second, ")^";
        move second to location;
      }
      if (self notin player)
      {
        print "(first getting ", (the)self, ")^";
        move self to player;
      }
      move child(self) to second;
      "You empty ", (the)self, " onto ", (the)second, ".";
    Fill:
      if (child(self) ~= 0)
        print_ret (The)self, " already has something in it.";
      if (second == nothing)
        print_ret (string)YOULL_HAVE_TO_TELL_ME_WHAT_TO, "fill it with.";
      if (second ofclass Liquid && TestScope(second))
        <<EmptyT (parent(second)) self>>;
      "You can only fill ", (the)self, " with liquids.";
  ],
has container open;

Class OpenableContainer
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
  before
  [;
    Receive:
      if (noun.size >= self.size)
        print_ret (The)noun, " won't fit in ", (the)self, ".";
  ],
has container openable;

!========================================
! Room 1: Vehicle Inspection Pit
!========================================
Object room01 "Vehicle Inspection Pit"
with
  description "You are now inside the narrow repair pit. Judging from the grease and the stains, the owner wasn't very fond of cleaning, but it's probably like this everywhere else in the world.",
  u_to room02,
  out_to room02,
has light;

!----------------------------------------
! Grease and stain
!----------------------------------------
Object grease "grease" room01
with
  name 'grease' 'stain',
  description "It's the product of countless hours of work repairing cars and the like.",
  before
  [;
    Touch:
      "You'd better not, as you don't have anything to clean yourself with.";
    Smell:
      "It smells like burned oil.";
  ],
has scenery;

!----------------------------------------
! Vehicle inspection pit
!----------------------------------------
Object pit "vehicle inspection pit" !room01
with
  name 'narrow' 'repair' 'vehicle' 'inspection' 'service' 'pit' 'sunken' 'area',
  description "It's a narrow sunken area to allow access to a vehicle's underside to grease or repair it.",
  before
  [;
    Enter:
      if (self in room02)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room01)
        <<Go FAKE_OUT_OBJ>>;
  ],
  found_in room01 room02,
has scenery;

!----------------------------------------
! Can of WD-40
!----------------------------------------
Object wd40 "can of WD-40" room01
with
  parse_name
  [ i;
    while (NextWord() == 'can' or 'of' or 'wd-40' or 'wd40' or 'wd' or 'spray' or 'nozzle' or 'lubricant' or 'oil' or 'instruction' or 'instructions//p')
      i++;
    return i;
  ],
  description "It's a small blue and yellow can with a spray nozzle. You can use it to moisten or lubricate almost anything. Also, spraying it on rusty metal parts will help you to unscrew them.",
  before
  [;
    Read:
      <<Examine self>>;
  ],
has;

!========================================
! Room 2: Service Station
!========================================
Object room02 "Service Station"
with
  description "The small service station is very quiet and, looking in one corner, you realise why. A corpse lies on the ground in the dim light and from the bad smell you would say that it has been there for at least two days. You can also see a service pit, going down in the ground. When you are done here you can exit by going west.",
  w_to room03,
  d_to room01,
  in_to room01,
  before
  [;
    Smell:
      "The smell inside the service station is revolting. You'd better hurry and go back out, if you don't want to throw up.";
  ],
has light;

!----------------------------------------
! Nelson's body
!----------------------------------------
Object nelson "man's body" room02
class Body
with
  article "a",
  parse_name
  [ i;
    while (NextWord() == 'mechanic' or 'dead' or 'body' or 'nelson' or 'nelson^s' or 'corpse' or 'man' or 'lifeless' or 'smelly' or 'heap')
      i++;
    return i;
  ],
  description "The man probably was the mechanic, and owner of the service station. He looks like a typical hard-working guy but, unfortunately, his working days are over, as he's crumpled in a lifeless and smelly heap on the floor. The name tag on his suit says 'Nelson'.",
  before
  [;
    Search:
      print "You search the man's pockets ";
      if (self hasnt general)
      {
        !move screwdriver to location;
        !scope_modified = true;
        give self general;
        "but you don't find anything useful.";
      }
      print_ret (string)SEARCH_AGAIN;
    Shoot:
      "He hasn't done anything to you. Besides, he's already dead.";
  ],
has animate; ! proper;

!----------------------------------------
! name tag
!----------------------------------------
Object name_tag "name tag" room02
with
	name 'name' 'tag',
	description	"It's just a name tag, with 'Nelson' written on it.",
  before
  [;
    Read:
      "Nelson";
  ]
has scenery;

!----------------------------------------
! suit
!----------------------------------------
Object suit "suit" room02
with
	name 'suit',
	description	"It's the suit the Nelson is wearing.",
  before
  [;
    Take:
      "Please show some respect. Besides, you wouldn't know what to do with it.";
  ]
has scenery;

!----------------------------------------
! screwdriver
!----------------------------------------
Object screwdriver "screwdriver"
with
	name 'screwdriver',
	description	"It's a metallic screwdriver. You can obviously unscrew things, with it.",
has;

!========================================
! Room 3: In Front of Service Station
!========================================
Object room03 "In Front of Service Station"
with
  description "You find yourself in front of a small service station. An old van is parked in one of the stalls. From here you can go east inside the station, or north. You can also go west, towards your car.",
  n_to room06,
  s_to "You came from the south, so there's no point to venturing back that way. You need to find your cousin, first.",
  e_to room02,
  w_to room04,
has light;

!----------------------------------------
! Environment (floating object)
!----------------------------------------
Object environment "environment"
with
  name 'environment' 'desolation' 'anguish' 'loneliness',
  description
  [;
    "You look around, but you only sense desolation, anguish and loneliness.";
  ],
  each_turn
  [;
    switch (random(50))
    {
      1: print_ret (italic)"^A crow flies high in the sky. It may have spotted something to feed on.";
      5: print_ret (italic)"^You feel the tension growing between your shoulder blades. You try to relax, but you can't.";
      10: print_ret (italic)"^A cloud of insects hovers briefly in the air, then flies off.";
      15: print_ret (italic)"^The silence of the town is unnerving.";
      20: print_ret (italic)"^You think you heard a voice in the distance, but you don't know whether it's real or just your imagination.";
      25: print_ret (italic)"^You think you sense a presence behind you, but when you turn you see nothing.";
      30: print_ret (italic)"^The anguish painfully assails you for a moment, then you get hold of yourself again.";
      35: print_ret (italic)"^You feel a trickle of perspiration running down your back. This place gives you the shivers.";
      40: print_ret (italic)"^Some sort of bug skitters across the ground in front of you, then it's gone.";
      45: print_ret (italic)"^A gust of wind reaches you, carrying the smell of death. Then it's gone.";
    }
  ],
  found_in room03 room04 room06 room10 room14 room18 room20 room24 room26 room29 room30,
has scenery;

!----------------------------------------
! gas pump
!----------------------------------------
Object gas_pump "gas pump" room03
	with
    article "a",
		name 'gas' 'petrol' 'pump',
		description
			[;
			  "It's an old-style gas pump, with analog dials to show the quantity of fuel delivered and the total amount due. There is a sign on it. ";
			],
			before
			[;
			  Read:
          "Out of Order";
			],
	has static;

!----------------------------------------
! dials on pump
!----------------------------------------
Object dials "dials" room03
with
	name 'dial' 'dials' 'analog' 'analogue',
	description	"The dials show the amount of fuel delivered and the total sum to be payed.",
  before
  [;
    Read:
      "They are hardly readable.";
    Rub:
      "You rub the dials, but can't make out the numbers. Since you have no need for this, you decide not to bother with it any more.";
  ],
has scenery;

!----------------------------------------
! sign on pump
!----------------------------------------
Object sign "sign" room03
with
	name 'sign',
	description	"It's a sheet of paper with writing on it.",
  before
  [;
    Read:
      "It says, 'Out of order'.";
  ],
has scenery;

!----------------------------------------
! parking stalls
!----------------------------------------
Object stalls "parking stalls" room03
with
	name 'parking' 'stall' 'stalls',
	description	"There are just a couple of them, and one is already taken.",
has scenery pluralname;

!----------------------------------------
! Van
!----------------------------------------
Object "van" room03
with
  article "an",
  name 'old' 'van',
  before
  [;
    Open:
      "You don't have the key. Besides, it's so old that you doubt you'd find anything useful in it.";
    Examine:
      "An old van sits in the shade, rusting. ";
    Search:
      if (self hasnt general)
      {
        give self general;
        "You search the van hoping to find a spark plug with no luck, so you leave it to its fate.";  
      }
      "You already searched the van and found nothing useful.";
    Climb:
      "What if you harm yourself in the process? Who would take care of your cousin, then?";
  ],
  !found_in room03 room04,
has scenery supporter;

!========================================
! Room 04: Outside Your Car
!========================================
Object room04 "Outside Your Car"
with
  description "Your car is parked at the side of a lonely country road. As you were driving north before you pulled over, you can go north to the front of the car or south to the back of the car. The deserted service station forecourt lies to the east while you can go west to enter your car.",
  n_to room29,
  e_to room03,
  s_to room30,
  w_to room28,
  in_to
  [;
    return room28;
  ],
has light;

!----------------------------------------
! Road (floating object)
!----------------------------------------
Object road "road"
with
  name 'country' 'road',
  description "It's the country road that leads to Creek Town, and from it further north.",
  found_in room03 room04 room29 room30,
has scenery;

!----------------------------------------
! Service Station (floating object)
!----------------------------------------
Object service_station "service station"
with
  name 'service' 'station' 'forecourt',
  description "The service station looks old and deserted. There's no one in sight.",
  found_in room04 room03 room02 room01 room28 room29 room30,
has scenery;

!========================================
! Room 28: In Your Car
!========================================
Object room28 "In Your Car"
with
  description
  [;
    print "You're inside your car in front of an old service station at the outskirts of a small town. ";
    if (car has general)
      print "The instruments are lit up and the engine is humming under the hood. A knob can be seen under the instrument panel.";
    else
      print "The instruments are dark and the engine is turned off. A knob can be seen under the instrument panel.";
    " You feel an unreal silence around you, and the sense of anguish is overwhelming. The only exit is out.";
  ],
  e_to
  [;
    if (telegram has general) {
      return room04;
    }
    else "You almost know it by heart, but you might want to read the telegram just one more time before proceeding.";
  ],
  out_to
  [;
    if (telegram has general) {
      return room04;
    }
    else "You almost know it by heart, but you might want to read the telegram just one more time before proceeding.";
  ],
  before
  [;
    Listen:
      "The silence is overwhelming.";
  ],
has light;

!----------------------------------------
! Your car
!----------------------------------------
Object car "car"
with
  name 'car',
  description
  [;
    print "It's an old piece of junk, but it's served you well for a long time and you don't feel like buying a new one. Not just yet, at least.^";
    if (self in room28)
    {
      if (car_key in ignition)
        print "As the car key is in the ignition, just turn the key to start it.";
      else
        print "You'd better insert a key in the ignition if you want to start the car.";
      " There's a knob under the instrument panel.";
    }
    if (self in room30)
    {
      print "The trunk is ";
      if (trunk has open)
        "open.";
      else
        "closed.";
    }
    if (self in room29)
    {
      print "The hood is ";
      if (hood has open)
        "open.";
      else
        "closed.";
    }
  ],
  before
  [;
    Tie:
      "If it just were so easy ...";
    Drive:
      if (self notin room28)
        "It might be easier to do that if you're in the car.";
      if (self hasnt general)
        "You need to start the engine first.";
      if (destroyed_equipment hasnt general)
        "Your car is now in working condition again, but you still haven't dealt with the origin of the larvae, so there's something else to do before driving away in search of your cousin Alan.";
      deadflag = 2;
      "Now that your car works again, you head to the main road and quickly drive away. As soon as you leave Creek Town you start to feel better. However, you feel there is still a lot to do before Earth can finally be declared safe. Moreover, your cousin is still nowhere to be found but, while heading out of town, an idea comes to your mind. You used to be part of a group of ufologists and parapsychologists and although you considered them to be a little weird, they always kept the group informed of any inexplicable phenomena occurring, anywhere on Earth. What about exploiting this opportunity to keep searching for your cousin while trying to protect Earth? What about creating a special Research Society (against) Alien Threats? 'Re.S.A.T.' is not a bad name, after all.";
    Enter:
      if (self in room28)
        "You're already in it.";
      if (self in room04)
        <<Go FAKE_IN_OBJ>>;
      "You can't enter it from here.";
    Exit:
      if (self in room28)
        <<Go FAKE_OUT_OBJ>>;
      "You're already outside the car.";
    Lock:
      if (self notin room04)
        "You can't lock it from here.";
    SwitchOn:
      if (self notin room01)
        "It might be easier to do that if you're in the car.";
      if (self has general)
        "The engine is already running.";
      print "If you're trying to start the engine, just ";
      if (car_key notin ignition)
        print "put the car key in the ignition and ";
      "turn the key.";
    SwitchOff:
      if (self notin room28)
        "It might be easier to do that if you're in the car.";
      if (car hasnt general)
        "The engine is already off.";
      "If you're trying to stop the engine, just turn the key.";
    Unlock:
      if (self notin room04)
        "You can't unlock it from here.";
  ],
  with_key car_key,
  found_in room28 room29 room30 room03 room04,
has lockable scenery container open;

!----------------------------------------
! V8 engine
!----------------------------------------
Object "V8 engine" room28
with
  name 'v8' 'engine',
  description "You can't see it from here. It's under the hood.",
  before
  [;
    SwitchOn:
      <<SwitchOn car>>;
    SwitchOff:
      <<SwitchOff car>>;
  ],
has scenery;

!----------------------------------------
! Dashboard
!----------------------------------------
Object dashboard "dashboard" room28
with
  name 'dashboard' 'instrument' 'panel' 'instruments',
  description "Steering wheel, ignition, knob under the instrument panel. Everything is where it should be.",
has scenery;

!----------------------------------------
! Knob under dashboard
!----------------------------------------
Object knob "knob under dashboard" room28
with
  name 'knob' 'picture',
  description "It has a little picture of a car with its hood open.",
  before
  [;
    Pull:
      if (hood hasnt locked)
        "Nothing happens, because you've already popped the hood.";
      give hood ~locked;
      "You hear a loud bump and the car's hood pops up a few centimetres.";
    Push:
      if (hood has locked)
        "Nothing happens because the hood is closed.";
      "If you're trying to close the hood, you'll have to get out and do that manually.";
    Turn:
      "This knob can only be pulled.";
  ],
has scenery;

!----------------------------------------
! Steering wheel
!----------------------------------------
Object steering_wheel "steering wheel" room28
with
  name 'steering' 'wheel',
  description "There is nothing special about the steering wheel. The ignition is beside it.",
  before
  [;
    Turn:
      "You can't turn the steering wheel while the car isn't moving. Wait until you're driving.";
  ],
has scenery;

!----------------------------------------
! Ignition
!----------------------------------------
Object ignition "ignition" room28
with
  name 'ignition',
  description
  [;
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun ~= car_key)
        "Don't be silly. The only thing that will fit in the ignition is the car key.";
  ],
has container open scenery;

!----------------------------------------
! Car key
!----------------------------------------
Object car_key "car key" ignition
with
  parse_name
  [ nw;
    nw = NextWord();
    if (nw == 'car')
    {
      if (NextWord() == 'key')
        return 2;
      if ((TestScope(car)) || (TestScope(big_car)))
        return 0;
      return 1;
    }
    if (nw == 'key')
      return 1;
    return 0;
  ],
  article "your",
  description "It's the key to your old car.",
  before
  [;
    Take:
      if (self in ignition && car has general)
        "You can't remove the car key while the engine's running. That's how it works.";
    Turn:
      if (self in ignition)
      {
        if (car has general)
        {
          give car ~general;
          "You turn the engine off.";
        }
        if (working_plug in hood)
        {
          give car general;
          print "With a loud noise, the car starts up. The big V8 purrs like a kitten. It's sweet music to your ears. ";
          if (destroyed_equipment hasnt general)
            "Your car is now in working condition again, but you still haven't dealt with the origin of the larvae, so there's something else to do before driving away in search of your cousin Alan.";
          "Now let's drive out of here.";
        }
        if (spark_plug hasnt general)
        {
          give spark_plug general;
          print "The starter motor gives a brief whir, then stops. You try again. ";
        }
        "You turn the key but nothing happens, so you try again. This time the engine starts up but it can't deliver the power as it should, then stops. Darn. Sounds like a spark plug problem.";
      }
      "You turn the key in your hand but, since it's not in the ignition, nothing happens.";
  ],
has;

!----------------------------------------
! Telegram
!----------------------------------------
Object telegram "telegram" room28 
with
  name 'telegram',
  description
  [;
    print "It's the telegram you received yesterday from your cousin Alan. It's dated January 17th, 1987. ";
    if (self hasnt general)
    {
	  "You already read it many times, but you cannot help reading it again.";
	}
    else
      "Enough reading, already. It's time to act.";
  ],
  before
  [;
    Read:
	    if (self in player)
      { 
        if (self hasnt general)
        {
	        print "You read through the telegram in haste one more time. Apparently, electrical interferences, strange noises and weird apparitions have been affecting Creek Town in the last few weeks. Some people were reported missing, many others left, so the town is mostly deserted. In particular, a few lines hit you like a stab in the heart.^^'COME TO CREEK TOWN STOP POSSIBLE THREAT TO THOUSANDS STOP I AM WAITING FOR YOU WITH ANXIETY STOP YOUR COUSIN ALAN STOP'^^You can't help wondering if your cousin's mental health has kept deteriorating through the years. Did you and your family overlook his needs? You should have been there for him, and you feel bad about it.^";
		      give self general;
		      rtrue;
	      }
        "You don't need to read it again. It's about time to find your cousin.";
      }
	    else "But you are not holding the telegram.";
    Drop:
      if (self in player)
      {
        if (location == room28)
        {
          move telegram to room28;
          "You don't need ", (the)noun, " anymore, so you drop it inside your car.";
        }
        else
        {
          move telegram to location;
          "You drop the telegram on the ground.";
        }
      }
      else "But you are not holding the telegram!";
  ],
  size 2,
has;

!========================================
! Room 29: In Front of Your Car
!========================================
Object room29 "In Front of Your Car"
with
  name 'front' 'car',
  description "You're at the front of your car, looking over the hood. The only available directions are to the south or towards the east. Only bushes can be seen towards the west.",
  e_to
  [;
    if (hood has open)
      "You'd better close the hood first. You don't know who could come around.";
    return room03;
  ],
  s_to
  [;
    if (hood has open)
      "You'd better close the hood first. You don't know who could come around.";
    return room04;
  ],
  n_to "You have no reason to go north.",
  before
  [;
    Listen:
      "The silence is overwhelming.";
  ],
has light;

!----------------------------------------
! Front of car
!----------------------------------------
Object front "front of your car"
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'front' or 'of' or 'your' or 'car')
    {
      i++;
      if (nw == 'car' && TestScope(car))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    "There's nothing special about it, except that it's old and ugly-looking. ";
    !<<Search self>>;
  ],
  found_in room04 room29,
has scenery;

!----------------------------------------
! Hood
!----------------------------------------
Object hood "hood" room29
with
  name 'bonnet' 'hood' 'hinged' 'cover' 'engine' 'bay',
  description
  [;
    print "The hood covers the engine bay. ";
    <<Search self>>;
  ],
  after
  [;
    Close:
      give self locked;
      "The hood clicks shut.";
  ],
has container lockable locked openable scenery;

!----------------------------------------
! Engine
!----------------------------------------
Object engine "V8 engine" hood
with
  name 'v8' 'engine',
  description "It's your car's engine. It's an old V8 model, but it's still in good condition.",
  before
  [;
    SwitchOff, SwitchOn:
      "It might be easier to do that if you're in the car.";
  ],
has static;

!----------------------------------------
! Faulty spark plug
!----------------------------------------
Object spark_plug "faulty spark plug" hood
with
  !name 'old' 'faulty' 'spark' 'plug',
  parse_name
  [ nw;
    nw = NextWord();
    if (nw == 'faulty' || nw == 'broken')
    {
      nw = NextWord();
      if (nw == 'plug')
        return 2;
      else 
        if (nw == 'spark' && NextWord() == 'plug')
          return 3;
    }
    if (nw == 'spark')
      if (NextWord() == 'plug')
        return 2;
    if (nw == 'plug')
      return 1;
    return 0;
  ],
  description "It's a spark plug. It's not working any more and you need to replace it.",
  before
  [;
    Remove, Replace, Take, Transfer:
      if (working_plug in player)
      {
        if (pliers in player)
        {
          remove self;
          move working_plug to hood;
          "You remove the faulty spark plug and throw it into the bushes at the side of the road. You then insert the new one and attach the cable.";
        }
        "You don't have anything to unscrew the faulty plug.";
      }
      else
      {
        print "There's no point removing it and lugging it around with you until you've got a replacement. ";
        if (pliers notin player)
          print "Besides, you don't have anything to unscrew the faulty plug.";
        "";
      }
    Spray:
      "There's no need to.";  
    Screw, Unscrew:
      if (pliers notin player)
        "You don't have anything suitable with you.";
      if (working_plug notin player)
        "There's no point removing it until you've got a replacement.";
      remove self;
      move working_plug to hood;
      "You remove the faulty spark plug and throw it into the bushes at the side of the road. You then insert the new one and attach the terminals.";
],
has;

!----------------------------------------
! bushes (floating object)
!----------------------------------------
Object bushes "bushes"
with 
	name 'bush' 'bushes//p',
	description
	[;
    "They grow wild on the side of the road, but there's nothing special about them.";
	],
  found_in room29 room30,
has scenery;

!========================================
