Object womans_arm "woman's arm" room23
with
  name 'right' 'arm',
  description 
  [;
    "It's pointing towards a filing cabinet in the corner.";
  ],
  before
  [;
    Examine:
      if (woman hasnt general)
      {
        give woman general;
        !give self general;
        move cabinet to room23;
      }
  ],
has scenery;

!----------------------------------------
! Cabinet
!----------------------------------------
Object cabinet "filing cabinet" 
class OpenableContainer
with
  name 'dusty' 'old' 'filing' 'cabinet',
  description
  [;
    print "It's a dusty old filing cabinet, the perfect complement to the office's furniture. ";
    <<Search self>>;
  ],
  before
  [;
    Pull, Push, Take:
      print_ret (string)TOO_HEAVY_TO_MOVE;
  ],
  after
  [;
    Open:
      give self general;
  ],
  size 10,
has container openable;

!----------------------------------------
! Cassette player
!----------------------------------------
Object cassette_player "cassette player" cabinet
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'cassette' or 'tape' or 'player' or 'recorder' or 'buttons')
    {
      i++;
      if (nw == 'cassette' or 'tape' && TestScope(cassette))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "It's a cassette player for playing cassettes. It has three buttons labelled PLAY, REWIND and EJECT. ";
    <<Search self>>;
  ],
  before
  [;
    LetGo:
      if (noun ~= battery)
        "You can't remove it manually, just press the EJECT button.";
    Receive:
      if (noun == cassette)
        "You'll need to specify whether you want to insert side A or side B.";
      if (noun ~= battery)
        print_ret (The)noun, " won't fit in the cassette player.";
  ],
  add_to_scope play_button eject_button rewind_button,
has container open;

!----------------------------------------
! Play button
!----------------------------------------
Object play_button "play button"
with
  name 'play' 'button',
  description "The play button is labelled 'PLAY'. It's used to play a cassette.",
  before
  [;
    Push:
      if (cassette notin cassette_player)
        "Nothing happens, as there's no cassette in the cassette player.";
      if (battery notin cassette_player)
        "Nothing happens, because there's no battery in the cassette player.";
      if (cassette_player hasnt general)
      {
        !Side A
        if (cassette has general)
          "Nothing happens. The cassette needs to be rewound.";
        give cassette general;
        "The player's motor starts up, with a low hum. Then, from the small speaker, a woman's voice clearly resounds.^^~Whoever you are, God sent you. Earth's destiny is in your hands! As weird as it may seem, we are undergoing an alien invasion. Those invaders are using some kind of larvae to infect human beings and snatch their bodies. Even animals are possibly affected by this unspeakable behaviour.~^^There's a cough, almost a gurgle, then the voice resumes.^^~There is a recording on the other side of this cassette, that corresponds to the sound made by the aliens before approaching their own machinery, and which should save you from their automatic protection system.~^^The voice becomes fainter, and pauses for a few seconds. Then, it starts again.^^~I managed to record it, but the price I had to pay is very high. Now I have little time left to live and I just want to tell you to do your best, because when the damned larvae have grown on the Earth, it will really be over.~^^There's a gasp and then nothing. The recording stops, leaving you in terror. All of a sudden, your cousin doesn't seem all that weird any more.";
      }
      else
      {
        !Side B
        if (cassette hasnt general)
          "Nothing happens. The cassette needs to be rewound.";
        give cassette ~general;
        print "A strange modulated sound comes out of the recorder's speaker. It keeps repeating itself like a kind of mathematical sequence. ";
        ! game specific action
        if ((side_b hasnt general) && (player in room09))
        {
          give side_b general;
          move intense_brightness to limbo;
          print "The weird light behind the door disappears. If the woman was right, the security system is now disabled, and it's safe to hit the door.";
        }
        "";
        ! end of action
      }
  ],
has scenery;

!----------------------------------------
! Rewind button
!----------------------------------------
Object rewind_button "rewind button"
with
  name 'rewind' 'button',
  description "The rewind button is labelled 'REWIND'. It's used to rewind a cassette.",
  before
  [;
    Push:
      if (cassette notin cassette_player)
        "Nothing happens, as there's no cassette in the cassette player.";
      if (battery notin cassette_player)
        "Nothing happens, because there's no battery in the cassette player.";
      if (cassette_player hasnt general)
      {
        !Side A
        if (cassette hasnt general)
          "Nothing happens. It must be fully rewound.";
        give cassette ~general;
        "The cassette spins wildly as it rewinds the cassette, then it comes to a stop.";
      }
      else
      {
        !Side B
        if (cassette has general)
          "Nothing happens. It must be fully rewound.";
        give cassette general;
        "The cassette spins wildly as it rewinds the cassette, then it comes to a stop.";
      }
  ],
has scenery;

!----------------------------------------
! EJECT button
!----------------------------------------
Object eject_button "EJECT button"
with
  name 'eject' 'button',
  description "The EJECT button is used to eject a cassette.",
  before
  [;
    Push:
      if (cassette notin cassette_player)
        "Nothing happens, as there's no cassette in the cassette player.";
      move cassette to player;
      print "The cassette pops out and you grab it";
      if (children(player) > MAX_CARRIED)
      {
        print ", but your hands are full and you drop ", (the)(youngest(player));
        move youngest(player) to real_location;
      }
      ".";
  ],
has scenery;

!----------------------------------------
! Cassette
!----------------------------------------
Object cassette "cassette" cabinet
with
  name 'c90' 'cassette' 'tape' 'two' 'sides',
  description
  [;
    print "It's a C90 cassette with two sides labelled Side A and Side B.";
    if (self in cassette_player)
    {
      print " It's currently in the cassette player with side ";
      if (cassette_player hasnt general)
        print "A";
      else
        print "B";
      print " facing up.";
    }
    "";
  ],
  before
  [;
    Eject:
      if (self notin cassette_player)
        "You can only eject the cassette if it's in a cassette player.";
      <<Push eject_button>>;
    Play:
      if (self notin cassette_player)
        "You can only play the cassette if it's in a cassette player.";
      <<Push play_button>>;
    Rewind:
      if (self notin cassette_player)
        "You can only rewind the cassette if it's in a cassette player.";
      <<Push rewind_button>>;
    Turn:
      if (self notin cassette_player)
        rfalse;
      if (cassette_player has general)
        give cassette_player ~general;
      else
        give cassette_player general;
      "You eject the cassette, turn it over and put it back into the cassette player.";
  ],
  add_to_scope side_a side_b,
has;

!----------------------------------------
! Side A
!----------------------------------------
Object side_a "side A"
with
  name 'side' 'a//',
  description
  [;
    if (cassette in cassette_player && cassette_player has general)
      "You can't see side A of the cassette, as it's facing down in the cassette player.";
    else
      "Side A of the cassette is labelled 'play me first'.";
  ],
  before
  [;
    Eject, Play, Rewind:
      <<(action) cassette>>;
    Insert:
      if (second == cassette_player)
      {
        if (cassette in cassette_player)
          "It's already in the cassette player.";
        move cassette to cassette_player;
        give cassette_player ~general;
        "You insert the cassette into the cassette player with side A facing up.";
      }
    Take:
      "That's part of the cassette.";
  ],
has scenery;

!----------------------------------------
! Side B
!----------------------------------------
Object side_b "side B"
with
  name 'side' 'b//',
  description
  [;
    if (cassette in cassette_player && cassette_player hasnt general)
      "You can't see side B of the cassette, as it's facing down in the cassette player.";
    else
      "Side B of the cassette is labelled 'surveillance system disabler'.";
  ],
  before
  [;
    Eject, Play, Rewind:
      <<(action) cassette>>;
    Insert:
      if (second == cassette_player)
      {
        if (cassette in cassette_player)
          "It's already in the cassette player.";
        move cassette to cassette_player;
        give cassette_player general;
        "You insert the cassette into the cassette player with side B facing up.";
      }
    Take:
      "That's part of the cassette.";
  ],
has scenery;

!========================================
! Room 24: Entrance to Underpass
!========================================
Object room24 "East Entrance to Underpass"
with
  description "You're near a narrow underpass, north of an old isolated building. You can go back to the town centre by going down towards the west, or you can go towards the old isolated building by going south.",
  s_to room18,
  d_to room25,
  w_to room25,
  before
  [;
    Smell:
      "The smell is disgusting.";
  ],
has light;

!----------------------------------------
! Underpass (floating object)
!----------------------------------------
Object "underpass"
with
  name 'narrow' 'dark' 'damp' 'fetid' 'underpass',
  description "It's just a narrow, dark, damp, and fetid underpass.",
  found_in room20 room24 room25 room26,
has scenery;

!========================================
! Room 25: Underpass
!========================================
Object room25 "Underpass"
with
  description "You're inside a dark and damp underpass that leads from the town to the outskirts. There are exits to the east and west.",
  !w_to room26,
  !e_to room24,
  e_to
  [;
    if (rats hasnt general)
      "The rats are blocking your way.";
    else
      return room24;
  ],
  w_to
  [;
    if (rats hasnt general)
      StopDaemon(rats);
    return room26;
  ],
  before
  [;
    Smell:
      "The smell is disgusting.";
  ],
has light;

!----------------------------------------
! Hungry rats
!----------------------------------------
Object rats "hungry rats" room25
with
  article "a pack of",
  name 'rat' 'pack' 'of' 'hungry' 'rats',
  description
  [;
    print "A pack of hungry rats swarm the underpass floor. ";
    if (self hasnt general)
      "Since they are blocking your way, you can only go back from where you came, unless you find a way to distract them.";
    else
      "They are now intent on picking the carcass of the dog, so you can walk past them.";
  ],
  life
  [;
    Attack:
      if (self hasnt general)
        "They are too many to be attacked, and it might be dangerous. Think about something else.";
      else
        "Don't waste your time. They are not midnding you anymore.";
  ],
  before
  [;
    Shoot:
      "They are too many to be taken down. Even if you managed to kill a couple of them, the others will eat you alive.";
    Take, Touch:
      "SLIMY. FILTHY. RATS. Yack!";
  ],
  daemon
  [;
    self.time_left++;
    print "^The rats";
    switch (self.time_left)
    {
      1: " look at you like a predator would look at its dinner.";
      2: "' posture is changing and getting more aggressive.";
      3: " are creeping towards you. It's your last chance to do something.";
      4: StopDaemon(self);
        deadflag = 1;
        " launch themselves at you, biting you in various parts of your body. You struggle desperately to get them off you and you manage to detach a few, but their numbers are overwhelming and, in a few minutes, your end is sealed.";
    }
  ],
  time_left 0,
has animate neuter pluralname;

!========================================
! Room 26: Entrance to Underpass
!========================================
Object room26 "West Entrance to Underpass"
with
  description "You're near the entrance to a fetid underpass north of the main road. You can either go south towards the outskirts of town, or down into the underpass to your east.",
  s_to room20,
  d_to
  [;
    if (rats hasnt general)
    {
      rats.time_left = 0;
      StartDaemon(rats);
    }
    return room25;
  ],
  e_to
  [;
    if (rats hasnt general)
    {
      rats.time_left = 0;
      StartDaemon(rats);
    }
    return room25;
  ],
  before
  [;
    Smell:
      "The smell is disgusting.";
  ],
has light;

!========================================
! Limbo
!========================================
Object limbo;

Object dummy_key;

!========================================
! Printing rules
!========================================
[ consultWord word i;
  for (i=0:i<WordLength(word):i++)
    print (char)LowerCase(WordAddress(word)->i);
];

[ DoesntOrDont obj;
  if (obj has pluralname)
    print "don't";
  else
    print "doesn't";
];

[ firstConsultWord word i;
  for (i=0:i<WordLength(word):i++)
    if (i == 0)
      print (char)UpperCase(WordAddress(word)->i);
    else
      print (char)LowerCase(WordAddress(word)->i);
];

[ italic text;
#Ifv5;
  style underline;
#Endif;
  print (string)text;
#Ifv5;
  style roman;
#Endif;
];

!========================================
! Other routines
!========================================
[ _UpdateDarkness p_silent _ceil _old_darkness _darkness;
  if (location == thedark)
    _old_darkness = true;
  _ceil = ScopeCeiling(player);
  if (_LookForLightInObj(_ceil, _ceil) == false)
    _darkness = true;
  if (_darkness ~= _old_darkness)
    scope_modified = true;
  if (_darkness)
    location = thedark;
  else
    location = real_location;
  if (_darkness ~= _old_darkness && p_silent == false)
  {
    new_line;
    <Look>;
  }
];

[ CantBeShot;
  if (second == nothing && revolver in player)
  {
    print "(with the revolver)^";
    second = revolver;
  }
  if (second == nothing && shotgun in player)
  {
    print "(with the shotgun)^";
    second = shotgun;
  }
  if (second == nothing)
    "You have no weapon.";
  if (second ~= revolver or shotgun)
    "You can't shoot anything with ", (ThatOrThose)second, ".";
  if (second == revolver && bullets.number == 0)
    "You pull the trigger, but nothing happens. The revolver must be out of bullets.";
  rfalse;
];

[ LowerCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'A' to 'Z': c = c + 32;
    202, 204, 212, 214, 221: c--;
    217, 218: c = c - 2;
    158 to 160, 167, 168, 208 to 210: c = c - 3;
    186 to 190, 196 to 200: c = c - 5 ;
    175 to 180: c = c - 6;
  }
  return c;
];

[ UpperCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'a' to 'z': c = c - 32;
    201, 203, 211, 213, 220: c++;
    215, 216: c = c + 2;
    155 to 157, 164, 165, 205 to 207: c = c + 3;
    181 to 185, 191 to 195: c = c + 5 ;
    169 to 174: c = c + 6;
  }
  return c;
];

!========================================
! Grammar
!========================================
Extend 'ask'
  * 'about' topic -> AskAbout;

Extend 'empty'
  * noun 'in'/'inside' noun -> EmptyT
  * noun 'from' noun -> Empty reverse;

Extend 'lock' first
  * noun -> Lock;

Extend 'look'
  * 'into' noun -> Search
  * 'behind'/'under' noun -> LookUnder;

Extend 'read' first
  * noun -> Read;

Extend only 'say' first
  * topic -> Say;

Extend only 'screw' replace
  * noun -> Screw
  * noun 'with' noun -> Screw
  * 'in' noun  -> Screw
  * 'in' noun 'with' noun -> Screw
  * noun 'off'/'out' -> Unscrew
  * noun 'off'/'out' 'with' noun -> Unscrew
  * 'off'/'out' noun -> Unscrew
  * 'off'/'out' noun 'with' noun-> Unscrew;

Extend only 'speak' replace
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Extend only 'turn'
  * noun 'over' -> Turn
  * 'over' noun -> Turn;

Extend 'unlock' first
  * noun -> Unlock;

Extend only 'unscrew' replace
  * noun -> Unscrew
  * noun 'with' noun -> Unscrew;

Verb meta 'about' 'info'
  * -> About;

Verb meta 'credits'
  * -> Credits;

Verb 'drive'
  * noun -> Drive;

Verb meta 'help' 'instructions'
  * -> Help;

Verb 'fire'
  * held -> Fire
  * held 'at' noun -> Shoot reverse
  * 'at' noun 'with' held -> Shoot;

Verb ',eject'
  * noun -> Eject;
Verb ',play'
  * noun -> Play;
Verb ',rewind'
  * noun -> Rewind;

Verb 'hint' 'clue'
  * -> Hint;

Verb 'inspect' = 'examine';

Verb 'kick' = 'attack';

Verb 'load'
  * noun -> Load
  * noun 'with' held -> Load;

Verb 'pour' = 'empty';

Verb 'lower'
  * -> Lower
  * noun -> Lower;

Verb 'raise'
  * -> Raise
  * noun -> Raise;

Verb 'shoot'
  * -> Shoot
  * noun -> Shoot
  * noun 'with' held -> Shoot
  * 'at' noun -> Shoot
  * 'at' noun 'with' held -> Shoot
  * held 'at' noun -> Shoot reverse;

Verb 'spray' 'lubricate' 'moisten' 'squirt'
  * -> Spray
  * noun -> Spray
  * noun 'with' noun -> Spray
  * noun 'on'/'onto' noun -> Spray reverse;

Verb 'talk' 'babble' 'chat' 'communicate' 'converse' 'gab' 'gossip'
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Verb 'replace'
  * noun -> Replace;

Verb 'use'
  * noun -> Use;

Verb 'xyzzy' 'plover' 'plugh' 'yoho'
  * -> MagicWord;

!========================================
! Actions
!========================================
[ AboutSub;
  print "This game is an adaptation of the Italian adventure 'Murray Shannon: I Semi del Male' by Bonaventura Di Bello. It was originally written using The Quill and Illustrator and published by Edizioni Hobby S.r.l. on the cover tape of 'Viking', no. 1, January 1987 for ZX Spectrum and C64.^^The data was extracted from the C64 version using UnQuill, translated to English and rewritten for a modern audience with the original author's permission. The new version includes many enhancements that weren't in the original. The coding was done using Inform 6 and the PunyInform library.^^";
  <<Credits>>;
];

[ AskAboutSub x count npc;
  objectloop (x in location && x has animate && x ~= player)
  {
    count++;
    npc = x;
  }
  if (count == 0)
    "There's no one here to answer your questions.";
  if (count == 1)
    <<Ask npc noun>>;
  "As there are multiple characters here, you'll have to specify who to ask, e.g. ASK MAN ABOUT DOG.";
];

[ CreditsSub;
  "Original concept, game design and coding by Bonaventura Di Bello.^English translation and game skeleton by Garry Francis.^Game redesign and coding by Gianluca Girelli.^Play testing by Robert Eggleston, Garry Francis, Kozelek+, Piergiorgio d'Errico, Allyson Gray, John Dennis and RJ Kowalski.";
];

[ CountSub;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun has pluralname)
    "There's more than one.";
  "There's only one.";
];

[ EjectSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't eject ", (ThatOrThose)noun, ".";
];

[ FireSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You'll have to tell me what to fire at.";
];

!Delete GoSub if diagonal directions are used
[ GoSub _prop;
  if (selected_direction == ne_to or nw_to or se_to or sw_to)
    "There are no diagonal directions in this game.";
  _prop = selected_direction;
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
  if (_prop == 0)
    return _RunTimeError(ERR_INVALID_DIR_PROP);
#Endif;
  return GoDir(_prop);
];

[ DriveSub;
  "You can't drive ", (ThatOrThose)noun, ".";
];

[ HelpSub;
  "Tell me what to do using simple commands starting with a verb.^^Use LOOK (or L) to refresh the location description. Identify all the objects in the description and EXAMINE (or X) each one. Read responses carefully for hints.^^Use compass directions (N, S, E, W, U and D) to move around. Draw a map as you go.^^Use GET or TAKE to take objects and DROP to drop them again. Use WEAR to wear things like clothing and REMOVE to remove anything that's currently worn. Use INVENTORY (or I) to see what you're carrying and wearing.^^Use AGAIN (or G) to repeat the last command.^^Use UNDO to undo the last command if you make a mistake.^^Use SAVE to save the game and RESTORE to restore it again.^^There are over 100 verbs that you can use, so if something doesn't work, try a different verb or a different way of doing things. Use HINT if you get stuck.^^For full instructions, see the game page at <https://bdb-project.itch.io/seeds-of-evil>.";
];

[ HintSub;
  "Examine everything you find and draw a map.";
];

[ LoadSub;
  if (ObjectIsUntouchable(noun))
    return;
  "That would be a neat trick.";
];

[ LockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_LOCK_NOT_A_LOCK, 'lock');
    rtrue;
  }
  if (noun has locked)
  {
    PrintMsg(MSG_LOCK_ALREADY_LOCKED);
    rtrue;
  }
  if (noun has open)
  {
    PrintMsg(MSG_LOCK_CLOSE_FIRST);
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to lock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_LOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun locked;
  run_after_routines_msg = MSG_LOCK_DEFAULT;
  run_after_routines_arg_1 = 'lock';
];

[ LookUnderSub;
  if (location == thedark)
    "But it's dark.";
  "You find nothing of interest.";
];

[ MagicWordSub;
  "Your cousin Alan comes out of nowhere and starts dancing like a puppet when its master starts pulling the strings. Then, just as suddenly as he came, he disappears.";
];

[ PlaySub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't play ", (ThatOrThose)noun, ".";
];

[ PourSub;
  if (ObjectIsUntouchable(noun))
    return;
  if (parent(noun) hasnt container)
    "You can't pour ", (ThatOrThose)noun, ".";
  <<Empty (parent(noun))>>;
];

[ PourTSub;
  if (ObjectIsUntouchable(noun))
    return;
  if (parent(noun) hasnt container)
    "You can't pour ", (ThatOrThose)noun, ".";
  if (ObjectIsUntouchable(second))
    return;
  <<EmptyT (parent(noun)) second>>;
];

[ RaiseSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't raise ", (ThatOrThose)noun, ".";
];

[ LowerSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't lower ", (ThatOrThose)noun, ".";
];

[ ReadSub;
  if (ObjectIsUntouchable(noun, true))
    "I suppose you read tea leaves, too";
  "There's nothing legible on ", (ThatOrThose)noun, ".";
];

[ ReplaceSub;
  "You can't replace ", (ThatOrThose)noun, ".";
];

[ RewindSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't rewind ", (ThatOrThose)noun, ".";
];

[ SaySub i;
  if (consult_words == 0)
    "You have nothing to say.";
  print "~";
  i = consult_from;
  print (firstConsultWord)i++;
  while (i < consult_from + consult_words)
    print " ", (consultWord)i++;
  print ".~^^";
  wn = consult_from;
  if (consult_words == 1 && NextWord() == 'xyzzy' or 'plover' or 'plugh' or 'yoho')
    <<MagicWord>>;
  if (AfterRoutines())
    return;
  "Nothing happens.";
];

[ ScrewSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You can't screw ", (ThatOrThose)noun, ".";
];

[ ShootSub;
  if (noun == nothing)
    "You point your finger in the air and say, ~Bang!~";
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (CantBeShot())
    rtrue;
  if (noun == player)
    "Are you feeling suicidal?";
  "You can't just go around shooting things arbitrarily. Choose your target carefully or it might get you killed.";
];

[ SpraySub;
  if (noun == nothing)
    "You'll have to tell me what to ", (address)verb_word, ".";
  if (second == nothing)
  {
    if (TestScope(wd40) && ~~ObjectIsUntouchable(wd40, true))
    {
      second = wd40;
      print "(with the can of WD-40)^";
    }
    else
      "You'll have to tell me what to ", (address)verb_word, " ", (ItOrThem)noun, " with.";
  }
  if (second ~= wd40)
    "You can't ", (address)verb_word, " anything with ", (ThatOrThose)second, ".";
  if (noun == second)
    "You can't ", (address)verb_word, " it with itself.";
  if (AfterRoutines() || keep_silent == 1)
    rtrue;
  "You ", (address)verb_word, " ", (the)noun, " with ", (the)second, ", but it doesn't do anything.";
];

[ TalkSub;
  if (noun == nothing)
    "You start talking to no one in particular.";
  if (noun == player)
    "You start talking to yourself, but it's a one-sided conversation.";
  if (RunLife(noun, ##Talk))
    rtrue;
  print_ret (The)noun, " ", (IsOrAre)noun, " not very talkative.";
];

[ UnlockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_UNLOCK_NOT_A_LOCK, 'unlock');
    rtrue;
  }
  if (noun hasnt locked)
  {
    PrintMsg(MSG_UNLOCK_ALREADY_UNLOCKED, 'unlock');
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to unlock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_UNLOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun ~locked;
  run_after_routines_msg = MSG_UNLOCK_DEFAULT;
  run_after_routines_arg_1 = 'unlock';
];

[ UnscrewSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You can't unscrew ", (ThatOrThose)noun, ".";
];

[ UseSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You'll have to be more explicit than that.";
];

End;
