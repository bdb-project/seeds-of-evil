!----------------------------------------
! Shotgun
!----------------------------------------
Object shotgun "shotgun" room22
with
  name 'shotgun' 'gun' 'dual-barrel' 'dual' 'barrel',
  description
  [;
    print "It's a dual-barrel shotgun used for hunting ducks and turkeys and things like that. It's ";
    if (self.number == 0)
      "not currently loaded.";
    print "loaded with ", self.number, " cartridge";
    if (self.number > 1)
      print "s";
    ".";
  ],
  before
  [;
    Search: 
      print "You search the shotgun";
      if (paper hasnt general)
      {
        move paper to location;
        give paper general;
        print " and, in the process, a piece of paper falls on the ground";
      }
      else 
        print " but you don't find anything else of interest";
      ".";
    Load:
      if (self.number > 0)
      {
        print "It's already loaded with ", self.number, " cartridge";
        if (self.number > 1)
          print "s";
        ".";
      }
      if (second == nothing && cartridges in player)
      {
        print "(with the cartridges)^";
        second = cartridges;
      }
      if (second == nothing)
        "You don't have anything suitable to load it with.";
      if (second ~= cartridges)
        "You can't load the shotgun with ", (ThatOrThose)second, ".";
      self.number = 2;
      move cartridges to limbo;
      print "You load the cartridges into the shotgun";
      if (paper hasnt general)
      {
        move paper to location;
        give paper general;
        print " and, in the process, a piece of paper falls on the ground";
      }
      ".";
  ],
  number 0,
  size 9,
has;

!----------------------------------------
! Cartridges
!----------------------------------------
Object cartridges "cartridges" room22
with
  article "two",
  name 'cartridges',
  description "They're shotgun cartridges.",
  before
  [;
    Count:
      "There are two cartridges.";
    Insert:
      if (second == shotgun)
        <<Load second self>>;
  ],
  size 3,
has pluralname;

!----------------------------------------
! Owner's note #2
!----------------------------------------
Object paper "piece of paper"  
with
  name 'piece' 'of' 'paper',
  description
  [;
    "It's a piece of paper that was concealed inside the shotgun. It fell on the ground when you loaded it. ";
  ],
  before
  [;
    Read:
	    if (self in player)
      { 
        print "You read the piece of paper with evergrowing fear and anxiety.^^'Creek Town is doomed. I now know it for a fact.^^I've been living here since I was born; I grew up with its establishment; I was one of the town's most respected people. But not anymore.^^When I understood what was going on I should have done something. I should have acted, but I didn't, and now those creatures have taken over.^^I cannot fight against them, and I cannot leave the town and risk spreading the disease myself. The poison will kill me, but it will also kill anything else inside of me. I made up my mind. Lord, forgive me.'^^";
        if (vial has general)
          print "So the man did kill himself, as you suspected. ";
        else 
          print "You wonder if the vial found in the coffin did contain a sort of poison. ";
        "But who, or what, are the creatures he was referring to? The larvae, or something else?";
		  }
      else "But you are not holding the document.";
  ],
  size 2,
has;

